<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.tobi.himedia_shop.project.mapper.ProductMapper">

    <!-- 상품 제목과 설명을 LIKE로 검색 -->
    <select id="searchProducts" resultType="com.example.tobi.himedia_shop.project.model.Product">
        SELECT *
        FROM products
        WHERE title LIKE CONCAT('%', #{searchTerm}, '%')
           OR content LIKE CONCAT('%', #{searchTerm}, '%');
    </select>


</mapper>
